generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum ProjectCategory {
  PERSONAL
  PROFESSIONAL
}

model Projects {
  id         String          @id @default(uuid())
  name       String
  content    String
  githubLink String
  image_url  String?
  priority   Int?
  category   ProjectCategory @default(PERSONAL)
  tags       String[]        @default([])
  isFeatured Boolean         @default(false)
}

model HeroWord {
  id        String   @id @default(uuid())
  text      String   @unique
  priority  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactOption {
  id        String   @id @default(uuid())
  label     String
  link      String
  icon      String?
  priority  Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NpmPackage {
  id          String          @id @default(uuid())
  name        String
  packageName String          @unique
  description String
  npmUrl      String?
  githubUrl   String?
  demoUrl     String?
  image_url   String?

  version     String?
  tags        String[]        @default([])

  isFeatured  Boolean         @default(false)
  priority    Int?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}